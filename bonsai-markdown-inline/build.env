# Grammar pins for bonsai-markdown-inline, consumed verbatim as
# `docker build` --build-arg values by build/regen.sh.
#
# This module compiles the companion *inline* grammar from
# tree-sitter-grammars/tree-sitter-markdown. The block grammar
# (bonsai-markdown) parses document structure and leaves the inline
# content of paragraphs, headings, and list items as a single `inline`
# leaf. Feeding that leaf's text into this parser produces tokens for
# emphasis, strong emphasis, code spans, links, images, and so on.
GRAMMAR_NAME=markdown-inline
GRAMMAR_REPO=https://github.com/tree-sitter-grammars/tree-sitter-markdown.git
GRAMMAR_TAG=v0.5.3
GRAMMAR_DIR=tree-sitter-markdown
GRAMMAR_SRC_SUBDIR=tree-sitter-markdown-inline
LANGUAGE_SYMBOL=tree_sitter_markdown_inline
GRAMMAR_HAS_SCANNER=1
