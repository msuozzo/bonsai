# Grammar pins for bonsai-go, consumed verbatim as `docker build`
# --build-arg values by build/regen.sh (and by CI's regen workflow).
# Keys must match the ARGs declared in Dockerfile.builder.
#
# tree-sitter-go ships parser.c only (no scanner.c), so
# GRAMMAR_HAS_SCANNER=0.
GRAMMAR_NAME=go
GRAMMAR_REPO=https://github.com/tree-sitter/tree-sitter-go.git
GRAMMAR_TAG=v0.25.0
GRAMMAR_DIR=tree-sitter-go
LANGUAGE_SYMBOL=tree_sitter_go
GRAMMAR_HAS_SCANNER=0
