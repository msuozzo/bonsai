# Grammar pins for bonsai-yaml, consumed verbatim as `docker build`
# --build-arg values by build/regen.sh (and by CI's regen workflow).
# Keys must match the ARGs declared in Dockerfile.builder.
#
# src/scanner.c textually #includes schema.core.c, so parser.c +
# scanner.c are the only translation units, exactly what the builder
# compiles. Do not add the schema.*.c files as separate units.
GRAMMAR_NAME=yaml
GRAMMAR_REPO=https://github.com/tree-sitter-grammars/tree-sitter-yaml.git
GRAMMAR_TAG=v0.7.2
GRAMMAR_DIR=tree-sitter-yaml
LANGUAGE_SYMBOL=tree_sitter_yaml
GRAMMAR_HAS_SCANNER=1
