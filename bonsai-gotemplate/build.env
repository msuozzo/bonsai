# Grammar pins for bonsai-gotemplate, consumed verbatim as `docker
# build` --build-arg values by build/regen.sh.
#
# The repo has no semver tags, so the tag here is a commit SHA from
# the master branch. Update by visiting the repo and copying the
# latest master commit.
GRAMMAR_NAME=gotemplate
GRAMMAR_REPO=https://github.com/ngalaiko/tree-sitter-go-template.git
GRAMMAR_TAG=master
GRAMMAR_DIR=tree-sitter-go-template
LANGUAGE_SYMBOL=tree_sitter_gotmpl
GRAMMAR_HAS_SCANNER=0
