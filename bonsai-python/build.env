# Grammar pins for bonsai-python, consumed verbatim as `docker build`
# --build-arg values by build/regen.sh (and by CI's regen workflow).
# Keys must match the ARGs declared in Dockerfile.builder.
GRAMMAR_NAME=python
GRAMMAR_REPO=https://github.com/tree-sitter/tree-sitter-python.git
GRAMMAR_TAG=v0.25.0
GRAMMAR_DIR=tree-sitter-python
LANGUAGE_SYMBOL=tree_sitter_python
GRAMMAR_HAS_SCANNER=1
