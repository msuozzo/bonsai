# Grammar pins for bonsai-terraform, consumed verbatim as `docker build`
# --build-arg values by build/regen.sh (and by CI's regen workflow).
# Keys must match the ARGs declared in Dockerfile.builder.
#
# Terraform is the HCL grammar's dialect: the repo (canonical home of
# the former MichaHoffmann/tree-sitter-hcl) keeps a self-contained
# generated parser (its own parser.c + scanner.c with tree_sitter_terraform
# symbols) under dialects/terraform. Apache-2.0 at the repo root, no
# NOTICE file.
GRAMMAR_NAME=terraform
GRAMMAR_REPO=https://github.com/tree-sitter-grammars/tree-sitter-hcl.git
GRAMMAR_TAG=v1.2.0
GRAMMAR_DIR=tree-sitter-hcl
GRAMMAR_SRC_SUBDIR=dialects/terraform
LANGUAGE_SYMBOL=tree_sitter_terraform
GRAMMAR_HAS_SCANNER=1
