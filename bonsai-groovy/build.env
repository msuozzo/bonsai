# Grammar pins for bonsai-groovy, consumed verbatim as `docker build`
# --build-arg values by build/regen.sh (and by CI's regen workflow).
# Keys must match the ARGs declared in Dockerfile.builder.
#
# tree-sitter-groovy ships parser.c only (no scanner.c), so
# GRAMMAR_HAS_SCANNER=0. Its tag is "initial" (non-semver) because the
# repository hasn't cut a real release yet.
GRAMMAR_NAME=groovy
GRAMMAR_REPO=https://github.com/murtaza64/tree-sitter-groovy.git
GRAMMAR_TAG=initial
GRAMMAR_DIR=tree-sitter-groovy
LANGUAGE_SYMBOL=tree_sitter_groovy
GRAMMAR_HAS_SCANNER=0
