# Grammar pins for bonsai-markdown, consumed verbatim as `docker build`
# --build-arg values by build/regen.sh (and by CI's regen workflow).
# Keys must match the ARGs declared in Dockerfile.builder.
#
# The tree-sitter-grammars/tree-sitter-markdown repo ships two grammars:
# the block-level one at tree-sitter-markdown/ and an inline one at
# tree-sitter-markdown-inline/. We compile the block grammar, which
# parses document structure (headings, lists, code blocks, links).
# Inline-content parsing would need a second wasm module.
GRAMMAR_NAME=markdown
GRAMMAR_REPO=https://github.com/tree-sitter-grammars/tree-sitter-markdown.git
GRAMMAR_TAG=v0.5.3
GRAMMAR_DIR=tree-sitter-markdown
GRAMMAR_SRC_SUBDIR=tree-sitter-markdown
LANGUAGE_SYMBOL=tree_sitter_markdown
GRAMMAR_HAS_SCANNER=1
